{
  "name": "engecon-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --out-dir dist",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:resolve": "prisma migrate resolve --applied 20260507000000_initial",
    "db:resolve:2": "prisma migrate resolve --applied 20260507000001_add_refresh_tokens",
    "db:resolve:3": "prisma migrate resolve --applied 20260509000000_add_ajuste_tipo_movimentacao"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.17",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.8.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
