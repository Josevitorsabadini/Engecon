# ─────────────────────────────────────────
# Banco de Dados
# ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ─────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET="troque-por-um-secret-longo-e-aleatorio"
JWT_EXPIRES_IN="30m"
REFRESH_TOKEN_SECRET="troque-por-outro-secret-longo-e-aleatorio"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ─────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"

# ─────────────────────────────────────────
# Seed (npm run db:seed)
# ─────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@engecon.com"
SEED_ADMIN_PASSWORD="troque-antes-de-rodar"
SEED_ADMIN_NOME="Administrador"
